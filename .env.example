# --- Veritabanı (Supabase) ---
# Supabase Dashboard > Project Settings > Database > Connection string
# DATABASE_URL: "Transaction pooler" (port 6543) — uygulama çalışırken kullanılır
# DIRECT_URL:   "Direct connection" (port 5432) — migration'lar için kullanılır
DATABASE_URL="postgresql://postgres.xxxx:SIFRE@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:SIFRE@db.xxxx.supabase.co:5432/postgres"

# --- Supabase (Realtime + Storage) ---
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- Auth ---
# Admin girişi için gizli anahtar (uzun rastgele bir değer)
ADMIN_KEY="degistir-bunu-uzun-rastgele-bir-deger"
# JWT imzalama gizli anahtarı (en az 32 karakter rastgele)
AUTH_SECRET="degistir-bunu-en-az-32-karakter-rastgele"

# --- AI (Groq — ücretsiz, kart gerektirmez: https://console.groq.com/keys) ---
GROQ_API_KEY="gsk_...."
# İsteğe bağlı model override (varsayılan: llama-3.3-70b-versatile)
# GROQ_MODEL="llama-3.3-70b-versatile"

# --- Uygulama ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
